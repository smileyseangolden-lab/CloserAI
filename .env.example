# ---- Database ----
POSTGRES_DB=closerai
POSTGRES_USER=closerai
POSTGRES_PASSWORD=closerai_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://closerai:closerai_dev_password@postgres:5432/closerai

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- Server ----
NODE_ENV=development
SERVER_PORT=4000
SERVER_URL=http://localhost:4000
CLIENT_URL=http://localhost:3000

# ---- Proxy host binding ----
# The docker proxy container is the only service bound to a host port.
# By default it binds to 127.0.0.1 (loopback only) so a host-level
# nginx can reverse-proxy it on :80/:443. If you want to expose the
# proxy directly to the public internet (e.g. for IP-based VPS testing
# before you have a domain), set PROXY_BIND=0.0.0.0.
PROXY_BIND=127.0.0.1
PROXY_PORT=14000

# ---- Auth ----
JWT_SECRET=replace-me-with-64-byte-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=replace-me-with-32-byte-random-string-aes256

# ---- Anthropic ----
# NOTE: API keys are NOT set here. Each organization configures its own
# Anthropic key in-app at Settings → Integrations. Keys are encrypted at
# rest and can be rotated without restarting the server.
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# ---- Email (SMTP default account, per-agent accounts override) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---- Rate limits ----
RATE_LIMIT_USER_PER_MIN=100
RATE_LIMIT_ORG_PER_MIN=1000

# ---- Frontend ----
VITE_API_URL=http://localhost:4000/api/v1
VITE_WS_URL=ws://localhost:4000
