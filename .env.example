# ---- Database ----
POSTGRES_DB=closerai
POSTGRES_USER=closerai
POSTGRES_PASSWORD=closerai_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://closerai:closerai_dev_password@postgres:5432/closerai

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- Server ----
NODE_ENV=development
SERVER_PORT=4000
SERVER_URL=http://localhost:4000
CLIENT_URL=http://localhost:3000

# ---- Auth ----
JWT_SECRET=replace-me-with-64-byte-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=replace-me-with-32-byte-random-string-aes256

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# ---- Email (SMTP default account, per-agent accounts override) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---- Rate limits ----
RATE_LIMIT_USER_PER_MIN=100
RATE_LIMIT_ORG_PER_MIN=1000

# ---- Frontend ----
VITE_API_URL=http://localhost:4000/api/v1
VITE_WS_URL=ws://localhost:4000
