# Environment-specific overrides for docker-compose.yml.
#
# Copy to `docker-compose.override.yml` (which is gitignored) and adjust.
# Compose auto-merges this file on top of the base whenever both are present.
#
# ⚠️ Use the `!override` YAML tag on `ports:` blocks. Without it, Compose
# APPENDS to the base file's ports list instead of replacing it, so you end
# up with two host bindings per service — including the base's 0.0.0.0
# binding, which exposes Postgres/Redis on the public internet.
#
# The layout below is what the canonical single-VPS, behind-nginx deployment
# uses: DB + Redis locked to localhost, client/server on localhost high
# ports that nginx proxies from :3000 and /api.

services:
  postgres:
    # Host-only bind + remapped external port keeps the DB off the internet.
    ports: !override
      - "127.0.0.1:15432:5432"

  redis:
    ports: !override
      - "127.0.0.1:16379:6379"

  server:
    # Behind an nginx /api/ proxy that forwards to 14000.
    ports: !override
      - "127.0.0.1:14000:4000"

  client:
    # Behind an nginx :3000 proxy that forwards to 13000.
    ports: !override
      - "127.0.0.1:13000:3000"
